{
  "name": "worklo-backend",
  "version": "1.0.0",
  "description": "Standalone Express backend for Worklo PSA",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "chmod -R +x node_modules/.bin && node_modules/.bin/tsc --noEmit false --noEmitOnError false || true && node_modules/.bin/tsc-alias || true",
    "start": "node -r tsconfig-paths/register dist/index.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.75.0",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.35.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.0",
    "nodemailer": "^8.0.3",
    "tailwind-merge": "^3.3.1",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.19.24",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0"
  }
}
